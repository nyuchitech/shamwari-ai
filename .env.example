# Shamwari AI — Python Backend (FastAPI on Fly.io)
# Copy to .env and fill in values

# CouchDB (local-first data layer)
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# Stytch Authentication (Mukoko B2C)
STYTCH_PROJECT_ID=
STYTCH_SECRET=

# Cloudflare R2 (S3-compatible storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shamwari-assets

# AI Backend
# (Internal — used when Workers or Vercel route to this service)
HOST=0.0.0.0
PORT=8000
