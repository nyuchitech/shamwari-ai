# Shamwari AI — Web App (shamwari.ai)
# Copy to .env.local and fill in values

# MongoDB Atlas (for Vercel Serverless — Route Handlers / Server Actions)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/shamwari

# Stytch Authentication (Mukoko B2C)
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=
STYTCH_PROJECT_ID=
STYTCH_SECRET=

# AI Backend (Fly.io FastAPI)
AI_API_URL=https://shamwari-ai.fly.dev
